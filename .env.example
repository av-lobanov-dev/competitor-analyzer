# Project
PROJECT_NAME=competitor-analyzer

# PostgreSQL
POSTGRES_DB=competitor_analyzer
POSTGRES_USER=competitor_user
POSTGRES_PASSWORD=replace_with_strong_password

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_USER=replace_with_admin_username
N8N_BASIC_AUTH_PASSWORD=replace_with_strong_password
N8N_ENCRYPTION_KEY=replace_with_random_encryption_key
N8N_SECURE_COOKIE=false
WEBHOOK_URL=http://localhost:5678/

# Timezone
TIMEZONE=UTC
GENERIC_TIMEZONE=UTC

# Competitor Analyzer application
APP_NAME=competitor-analyzer
NODE_ENV=production
WORKER_POLL_INTERVAL_MS=15000
POSTGRES_POOL_MAX=5
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# Новые воркеры выключены, пока их бизнес-логика не реализована.
ENABLE_ANALYSIS_WORKER=false
ENABLE_SCRAPING_WORKER=false

# Существующий Playwright queue runner продолжает работать.
ENABLE_LEGACY_WORKER=true
